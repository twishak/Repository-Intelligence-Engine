# Required - get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional overrides - defaults shown below (see src/codebase_agent/config.py
# for the full list of settings, including data directory locations).

# GROQ_MODEL=llama-3.3-70b-versatile

# Forces the embedding model onto a specific device. Default is None, which
# auto-detects: cuda if a matching torch build sees a GPU, else cpu. Set this
# if auto-detection picks the wrong device (e.g. a CUDA torch build is
# installed but you want to force CPU).
# EMBEDDING_DEVICE=cpu

# Host/port for `python scripts/serve_api.py`. Set API_HOST=0.0.0.0 to accept
# connections from outside localhost (e.g. inside a container).
# API_HOST=127.0.0.1
# API_PORT=8000
